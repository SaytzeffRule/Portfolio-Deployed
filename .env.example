# =============================================================================
# Portfolio — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# IMPORTANT: Never commit the actual .env file. It is listed in .gitignore.

# URL to your resume PDF hosted on S3 (or any public/signed URL).
# Used by the Resume section to provide a downloadable link.
VITE_RESUME_URL=https://your-bucket.s3.your-region.amazonaws.com/resume.pdf

# URL to your profile photo (optional — used in the About section).
# Upload to S3 and reference the public URL here.
VITE_PROFILE_IMG_URL=https://your-bucket.s3.your-region.amazonaws.com/profile.jpg

# (Optional) Contact form backend URL. If you wire up a form handler,
# set its endpoint here. Otherwise the form logs to console.
VITE_CONTACT_ENDPOINT=
